import cv2
import numpy as np
import os
from tkinter import filedialog
import tkinter as tk

def auto_sharpen_image(input_path, output_path=None):
    # Read image
    img = cv2.imread(input_path)
    if img is None:
        print("Error: Could not read image")
        return False
    
    # Step 1: Unsharp masking
    blurred = cv2.GaussianBlur(img, (0, 0), 3.0)
    sharpened = cv2.addWeighted(img, 1.5, blurred, -0.5, 0)
    
    # Step 2: High-pass filter sharpening
    kernel = np.array([[-1, -1, -1],
                       [-1,  9, -1],
                       [-1, -1, -1]]) / 1.0
    final = cv2.filter2D(sharpened, -1, kernel)
    
    # Step 3: Adjust brightness if needed (target 140)
    lab = cv2.cvtColor(final, cv2.COLOR_BGR2LAB)
    l, a, b = cv2.split(lab)
    mean_l = np.mean(l)
    if mean_l > 160:  # too bright
        l = cv2.add(l, -15)
    elif mean_l < 100:  # too dark
        l = cv2.add(l, 15)
    lab = cv2.merge((l, a, b))
    final = cv2.cvtColor(lab, cv2.COLOR_LAB2BGR)
    
    # Save
    if output_path is None:
        name, ext = os.path.splitext(input_path)
        output_path = f"{name}_sharpened{ext}"
    
    cv2.imwrite(output_path, final, [cv2.IMWRITE_JPEG_QUALITY, 100])
    print(f"Sharpened image saved to: {output_path}")
    return True

# GUI to select file
root = tk.Tk()
root.withdraw()
file_path = filedialog.askopenfilename(title="Select Image to Sharpen", 
                                        filetypes=[("Image files", "*.jpg *.jpeg *.png")])
if file_path:
    auto_sharpen_image(file_path)
    print("Done! Now upload the sharpened image to Adobe Stock.")
else:
    print("No file selected.")
